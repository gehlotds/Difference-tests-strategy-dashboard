server <- function(input, output, session) {
  
  # ---- Core reactives ----
  
  active_ctx <- reactive(CONTEXTS[[input$context_type]])
  
  # Sync cost and power defaults when context changes
  observeEvent(input$context_type, {
    ctx <- CONTEXTS[[input$context_type]]
    updateNumericInput(session, "ds_cost_miss",  value = ctx$cost_miss)
    updateNumericInput(session, "ds_cost_alarm", value = ctx$cost_alarm)
    updateSliderInput(session,  "pw_alpha",      value = ctx$alpha)
    updateSliderInput(session,  "pw_power",      value = ctx$target_power)
    updateSliderInput(session,  "pw_d_true",     value = ctx$d_R)
  })
  
  observeEvent(input$global_n, updateNumericInput(session, "global_x", max = input$global_n))
  observeEvent(input$sp_n,     updateNumericInput(session, "sp_x",     max = input$sp_n))
  
  cur_test <- reactive(TEST_DATA[[input$global_method]])
  cur_calc <- reactive(calc_d_prime(input$global_n, input$global_x, cur_test()))
  cur_ci   <- reactive({
    cc <- cur_calc(); if (is.na(cc$d_prime)) return(NULL)
    calc_ci(cc$d_prime, cc$se, cc$pa, input$global_n, cur_test()$pc)
  })
  cur_strat <- reactive({
    cc  <- cur_calc(); ctx <- active_ctx()
    if (is.na(cc$d_prime)) return(NULL)
    calc_strategy_table(cc$d_prime, cc$se, ctx$d_R,
                        ctx$alpha, input$ds_cost_miss, input$ds_cost_alarm)
  })
  
  # Safe method list for power tab
  pw_methods <- reactive({
    m <- input$pw_methods
    if (is.null(m) || length(m) == 0) "2AFC" else m
  })
  
  # ---- Shared context card ----
  ctx_html <- reactive({
    ctx <- active_ctx()
    HTML(paste0(
      "<div class='ctx-card'>",
      "<b>Decision Context: ", ctx$label, "</b><br>",
      "Consumer-relevant difference <b>d_R = ", ctx$d_R, "</b> &nbsp;|&nbsp; ",
      "\u03b1 = <b>", ctx$alpha, "</b> &nbsp;|&nbsp; ",
      "Target power = <b>", ctx$target_power * 100, "%</b> &nbsp;|&nbsp; ",
      "Cost weights: missed diff = <b>", ctx$cost_miss,
      "</b>, false alarm = <b>", ctx$cost_alarm, "</b><br>",
      "<span style='color:#555; font-size:12px;'>", ctx$description, "</span>",
      "</div>"
    ))
  })
  output$ctx_card_t1 <- renderUI(ctx_html())
  output$ctx_card_t2 <- renderUI(ctx_html())
  output$ctx_card_t3 <- renderUI(ctx_html())
  output$ctx_card_t4 <- renderUI(ctx_html())
  
  output$sidebar_hint <- renderText({
    ctx <- active_ctx()
    paste0(ctx$label, "\nd_R = ", ctx$d_R, "  \u03b1 = ", ctx$alpha,
           "  Power \u2265 ", ctx$target_power * 100, "%")
  })
  
  # ============================================================
  # TAB 1
  # ============================================================
  
  output$t1_d_val <- renderText({
    cc <- cur_calc()
    if (is.na(cc$d_prime)) "d\u2019 = N/A"
    else paste0("d\u2019 = ", round(cc$d_prime, 3))
  })
  
  output$t1_verdict <- renderUI({
    cc  <- cur_calc(); ctx <- active_ctx()
    v   <- verdict_text(cc$d_prime, if (is.na(cc$se)) 0 else cc$se, ctx$d_R)
    cls <- paste0("vrd-", v$color)
    p_below_pct <- if (!is.na(v$p_below)) round(v$p_below * 100, 1) else NA
    HTML(paste0(
      "<div class='", cls, "'>",
      "<span style='font-size:16px; font-weight:700;'>", v$text, "</span><br><br>",
      if (!is.na(p_below_pct))
        paste0("<b>P(true d\u2019 &lt; d_R&nbsp;|&nbsp;data)&nbsp;=&nbsp;",
               p_below_pct, "%</b>",
               " <span style='font-size:11px; color:#555;'>(flat prior on d\u2019)</span><br><br>")
      else "",
      v$detail,
      "</div>"
    ))
  })
  
  output$t1_stats <- renderText({
    cc  <- cur_calc(); ci <- cur_ci(); ctx <- active_ctx()
    if (is.na(cc$d_prime) || is.null(ci)) return("Check inputs: X must be <= N")
    paste0(
      "d'                   = ", round(cc$d_prime, 3), "\n",
      "SE                   = ", round(cc$se, 3), "\n",
      "95% CI for d'        = [", round(ci$d_ci[1], 3), " , ", round(ci$d_ci[2], 3), "]\n",
      "Pa (prop. correct)   = ", round(cc$pa, 3), "\n",
      "Pd = Pa - Pc         = ", round(ci$pd, 3),
      "  (prob. of discrimination)\n",
      "95% CI for Pd        = [", round(ci$pd_ci[1], 3), " , ", round(ci$pd_ci[2], 3), "]\n",
      "P(d'<d_R) [flat prio]= ", round(pnorm(ctx$d_R, cc$d_prime, cc$se) * 100, 1),
      "% (d_R = ", ctx$d_R, ")"
    )
  })
  
  output$t1_method_table <- renderTable({
    t <- cur_test()
    pc_frac <- switch(t$test_name,
                      "3AFC"    = "1/3",
                      "Triangle"= "1/3",
                      "Tetrad"  = "1/6",
                      as.character(t$pc)
    )
    data.frame(
      Characteristic = c("Reference product", "Samples per trial", "Possible sequences",
                         "Sequence variance", "Memory effect",
                         "Chance level (Pc) — guessing probability", "Model"),
      Value = c(t$reference_product, t$samples_per_trial, t$possible_sequences,
                t$variance_sequence, t$memory_effect,
                paste0(round(t$pc, 4), "  (", pc_frac, " — 1 in ",
                       round(1 / t$pc), " by chance)"),
                t$model)
    )
  }, striped = TRUE, hover = TRUE, spacing = "s", width = "100%")
  
  output$t1_method_fit <- renderText(METHOD_CONTEXT_FIT[[input$global_method]])
  
  output$t1_cognitive <- renderText(cur_test()$cognitive_strategy)
  
  output$t1_sdt_plot <- renderPlotly({
    cc  <- cur_calc(); if (is.na(cc$d_prime)) return(plot_ly())
    ctx <- active_ctx()
    td  <- cur_test()
    d   <- cc$d_prime
    x   <- seq(-3.5, max(3.5, d + 2.5), 0.04)
    ym  <- max(dnorm(x, 0, 1))
    # M1: title reflects whether the SDT picture is exact or a simplification
    plot_title <- if (td$model == "SDT")
      paste0("SDT model for A-not-A  (d' = ", round(d, 2), ")")
    else
      paste0("Simplified SDT illustration for ", td$test_name,
             "  (d' = ", round(d, 2), ") — true Thurstonian decision space differs")
    plot_ly() %>%
      add_lines(x = x, y = dnorm(x, 0, 1), name = "Noise (reference)",
                line = list(color = "#3498db", width = 2.5)) %>%
      add_lines(x = x, y = dnorm(x, d, 1), name = "Signal (test sample)",
                line = list(color = "#e74c3c", width = 2.5)) %>%
      add_lines(x = c(ctx$d_R, ctx$d_R), y = c(0, ym * 1.1),
                name = paste0("Consumer-relevant d_R = ", ctx$d_R),
                line = list(color = "#8e44ad", dash = "dot", width = 2)) %>%
      layout(
        title  = plot_title,
        xaxis  = list(title = "Sensory Intensity"),
        yaxis  = list(title = "Density"),
        showlegend = TRUE,
        margin = list(t = 40),
        annotations = list(list(
          x = d / 2, y = ym * 1.18,
          text = paste0("d' = ", round(d, 2)), showarrow = FALSE,
          font = list(size = 13, color = "#333")
        ))
      )
  })
  
  output$t1_prior_plot <- renderPlotly({
    req(input$expert_mode); ctx <- active_ctx()
    x <- seq(0, 3, 0.02)
    y <- dnorm(x, input$prior_mean, input$prior_sd)
    plot_ly() %>%
      add_lines(x = x, y = y, name = "Prior on d\u2019",
                line = list(color = "#3498db", width = 2)) %>%
      add_lines(x = c(ctx$d_R, ctx$d_R), y = c(0, max(y) * 0.95),
                name = paste0("d_R = ", ctx$d_R),
                line = list(color = "#8e44ad", dash = "dash", width = 1.5)) %>%
      layout(xaxis = list(title = "d\u2019"), yaxis = list(title = "Density"),
             showlegend = FALSE, margin = list(t = 5))
  })
  
  # ================================
  # TAB 2
  # ================================
  
  # Context alpha label (used in UI note)
  output$pw_ctx_alpha_label <- renderText(as.character(active_ctx()$alpha))
  
  # Min N at context d_R (text block in left panel)
  output$pw_n_at_dR <- renderText({
    ctx     <- active_ctx()
    methods <- pw_methods()
    out <- sapply(methods, function(m) {
      n <- calc_min_n(ctx$d_R, m, TEST_DATA[[m]]$pc,
                      ctx$alpha, ctx$target_power)
      paste0(m, ": ", if (is.na(n)) ">500" else n)
    })
    paste(out, collapse = "\n")
  })
  
  # Min N at manual d' (expert mode text block)
  output$pw_n_manual <- renderText({
    methods <- pw_methods()
    out <- sapply(methods, function(m) {
      n <- calc_min_n(input$pw_d_true, m, TEST_DATA[[m]]$pc,
                      input$pw_alpha, input$pw_power)
      paste0(m, ": ", if (is.na(n)) ">500" else n)
    })
    paste(out, collapse = "\n")
  })
  
  # Power curves vs true d'
  output$pw_power_curve <- renderPlotly({
    ctx     <- active_ctx()
    methods <- pw_methods()
    d_seq   <- seq(0.1, 2.5, 0.04)
    colors  <- c("#e74c3c","#3498db","#2ecc71",
                 "#f39c12","#9b59b6","#1abc9c")
    p <- plot_ly()
    for (i in seq_along(methods)) {
      m  <- methods[i]
      pc <- TEST_DATA[[m]]$pc
      pw <- sapply(d_seq, function(d)
        calc_power(input$global_n, d, m, pc, input$pw_alpha))
      p  <- add_lines(
        p, x = d_seq, y = pw, name = m,
        line = list(
          color = colors[(i - 1) %% length(colors) + 1],
          width = 2.5
        )
      )
    }
    p %>%
      add_lines(
        x = d_seq, y = rep(input$pw_power, length(d_seq)),
        name = "Target power",
        line = list(color = "#333", dash = "dash", width = 1.5)
      ) %>%
      add_lines(
        x = c(ctx$d_R, ctx$d_R), y = c(0, 1),
        name = paste0("Consumer-relevant d_R = ", ctx$d_R),
        line = list(color = "#8e44ad", dash = "dot", width = 2)
      ) %>%
      layout(
        xaxis  = list(title = "True d’"),
        yaxis  = list(title = "Power", range = c(0, 1.05)),
        title  = paste0("Power curves  (N = ",
                        input$global_n, ", \u03b1 = ",
                        input$pw_alpha, ")"),
        shapes = list(list(
          type = "rect", x0 = 0, x1 = ctx$d_R, y0 = 0, y1 = 1,
          fillcolor = "rgba(142,68,173,0.05)",
          line = list(width = 0)
        )),
        annotations = list(list(
          x = ctx$d_R, y = 1.03,
          text = paste0("d_R = ", ctx$d_R),
          showarrow = FALSE,
          font = list(size = 11, color = "#8e44ad"),
          xanchor = "left"
        ))
      )
  })
  
  # Power sentence under the curve
  output$pw_sentence <- renderText({
    ctx     <- active_ctx()
    methods <- pw_methods()
    power_sentence(methods, input$global_n, ctx$d_R, input$pw_alpha)
  })
  
  # Minimum N by d' target — table with nicer headers
  output$pw_n_table <- renderDT({
    ctx       <- active_ctx()
    d_targets <- sort(unique(c(ctx$d_R, 0.5, 0.8, 1.0, 1.5)))
    methods   <- pw_methods()
    
    # Build rows: Method + N for each d' target
    rows <- lapply(methods, function(m) {
      pc <- TEST_DATA[[m]]$pc
      ns <- sapply(d_targets, function(d)
        calc_min_n(d, m, pc, input$pw_alpha, input$pw_power))
      c(
        Method = m,
        setNames(as.list(ifelse(is.na(ns), ">500", as.character(ns))),
                 paste0("d'=", d_targets))
      )
    })
    
    df <- as.data.frame(
      do.call(rbind, lapply(rows, as.data.frame, stringsAsFactors = FALSE)),
      stringsAsFactors = FALSE
    )
    
    dR_col <- paste0("d'=", ctx$d_R)
    
    # Human‑friendly column labels (visible headers)
    pretty_cols <- c(
      "Method",
      paste0("d' = ", d_targets)
    )
    
    dt <- datatable(
      df,
      rownames = FALSE,
      caption  = paste0(
        "Min N for ", round(input$pw_power * 100),
        "% power  (\u03b1 = ", input$pw_alpha, ")"
      ),
      options  = list(pageLength = 8, dom = "t", scrollX = TRUE),
      colnames = pretty_cols
    )
    
    # Highlight the column corresponding to d_R
    if (dR_col %in% names(df)) {
      dt <- dt %>%
        formatStyle(
          dR_col,
          backgroundColor = "#d6eaf8",
          fontWeight      = "bold"
        )
    }
    dt
  })
  
  # Power vs N at d_R
  output$pw_n_curve <- renderPlotly({
    ctx     <- active_ctx()
    methods <- pw_methods()
    n_seq   <- seq(5, 300, 5)
    colors  <- c("#e74c3c","#3498db","#2ecc71",
                 "#f39c12","#9b59b6","#1abc9c")
    p <- plot_ly()
    for (i in seq_along(methods)) {
      m  <- methods[i]
      pc <- TEST_DATA[[m]]$pc
      pw <- sapply(n_seq, function(n)
        calc_power(n, ctx$d_R, m, pc, input$pw_alpha))
      p  <- add_lines(
        p, x = n_seq, y = pw, name = m,
        line = list(
          color = colors[(i - 1) %% length(colors) + 1],
          width = 2.5
        )
      )
    }
    p %>%
      add_lines(
        x = n_seq, y = rep(input$pw_power, length(n_seq)),
        name = "Target power",
        line = list(color = "#333", dash = "dash")
      ) %>%
      layout(
        xaxis = list(title = "N panelists"),
        yaxis = list(title = "Power", range = c(0, 1.05)),
        title = paste0(
          "Power vs N at consumer-relevant d_R = ", ctx$d_R,
          "  (\u03b1 = ", input$pw_alpha, ")"
        )
      )
  })
  
  # Power sentence under the N‑curve (same text as above)
  output$pw_n_sentence <- renderText({
    ctx     <- active_ctx()
    methods <- pw_methods()
    power_sentence(methods, input$global_n, ctx$d_R, input$pw_alpha)
  })
  
  
  # ============================================================
  # TAB 3 — Decision Strategy (server)
  # ============================================================
  
  output$ds_recommendation_text <- renderUI({
    df <- cur_strat(); if (is.null(df)) return(HTML("—"))
    ctx <- active_ctx()
    bs  <- best_strategy_name(df)
    el  <- df$"Expected Loss"[df$Strategy == bs]
    pb  <- df$"P(d' < d_R)"[1]   # same for all rows (posterior, flat prior)
    HTML(paste0(
      "<div class='best-box'>",
      "<b>Recommended framework: ", bs, "</b><br>",
      "Gives lowest expected loss (<b>", round(el, 2), "</b>) under <em>", ctx$label, "</em>.<br>",
      "P(true d' &lt; d_R&nbsp;|&nbsp;data) = <b>", round(pb * 100, 1),
      "%</b> <span style='font-size:11px; color:#555;'>(flat prior on d')</span>",
      "</div>"
    ))
  })
  
  
  output$ds_boundary_plot <- renderPlotly({
    cc  <- cur_calc(); if (is.na(cc$d_prime)) return(plot_ly())
    ctx <- active_ctx()
    df  <- cur_strat()
    bs  <- if (!is.null(df)) best_strategy_name(df) else "—"
    d   <- cc$d_prime; se <- cc$se
    d_grid <- seq(0, max(3.5, d + 1.5), 0.03)
    
    # CI-based NHST: margin = how far lower 95% CI is above 0 (negate for approval)
    ci_lo_grid    <- d_grid - qnorm(0.975) * se
    ci_hi_grid    <- d_grid + qnorm(0.975) * se
    nhst_margin   <- clamp((ci_lo_grid - 0) / se, -10, 10)
    nhst_approve  <- plogis(-nhst_margin)            # high when CI lower <= 0
    
    # Equivalence (TOST): margin = (d_R - CI_upper)/SE, positive = approved
    equiv_margin  <- clamp((ctx$d_R - ci_hi_grid) / se, -10, 10)
    equiv_approve <- plogis(equiv_margin)
    
    # Bayesian: P(d' < d_R | data), flat prior
    bayes_approve <- pnorm(ctx$d_R, mean = d_grid, sd = se)
    
    plot_ly() %>%
      add_lines(x = d_grid, y = nhst_approve,
                name = "NHST (no sig. diff. from 0)",
                line = list(color = "#e74c3c", width = 2.5)) %>%
      add_lines(x = d_grid, y = equiv_approve,
                name = "Equivalence (CI entirely < d_R)",
                line = list(color = "#3498db", width = 2.5)) %>%
      add_lines(x = d_grid, y = bayes_approve,
                name = "Bayesian P(d' < d_R) — flat prior",
                line = list(color = "#2ecc71", width = 2.5)) %>%
      add_lines(x = c(d, d), y = c(-0.05, 1.1),
                name = paste0("Observed d' = ", round(d, 2)),
                line = list(color = "#333", dash = "dash", width = 1.5)) %>%
      add_lines(x = c(ctx$d_R, ctx$d_R), y = c(-0.05, 1.1),
                name = paste0("Consumer-relevant d_R = ", ctx$d_R),
                line = list(color = "#8e44ad", dash = "dot", width = 2)) %>%
      layout(
        xaxis  = list(title = "d'"),
        yaxis  = list(title = "P(Approve)", range = c(-0.08, 1.18)),
        title  = paste0("Decision boundaries  |  SE = ", round(se, 3),
                        "  |  Current best: ", bs),
        shapes = list(list(
          type = "rect", x0 = 0, x1 = ctx$d_R, y0 = -0.08, y1 = 1.1,
          fillcolor = "rgba(142,68,173,0.05)", line = list(width = 0)
        )),
        annotations = list(list(
          x = ctx$d_R, y = 1.14,
          text = paste0("d_R = ", ctx$d_R),
          showarrow = FALSE, font = list(size = 11, color = "#8e44ad"),
          xanchor = "left"
        ))
      )
  })
  
  output$ds_decision_text <- renderUI({
    cc  <- cur_calc(); if (is.na(cc$d_prime)) return(HTML("—"))
    ctx <- active_ctx()
    d   <- cc$d_prime; se <- cc$se
    ci_lower <- d - qnorm(0.975) * se    # 95% CI lower bound
    ci_upper <- d + qnorm(0.975) * se    # 95% CI upper bound
    p_below  <- pnorm(ctx$d_R, d, se)    # flat prior posterior
    cutoff   <- if (isTRUE(input$expert_mode)) input$ds_bayes_cutoff else 0.80
    
    # Smooth NHST approval probability
    nhst_smooth_pct <- round(plogis(-clamp((ci_lower - 0) / se, -10, 10)) * 100, 1)
    
    # NHST text
    nhst_dec  <- if (ci_lower <= 0)
      paste0("✅ APPROVE — lower 95% CI does not exceed 0 (no significant difference)",
             " <span style='font-size:11px; color:#888;'>[smooth P(Approve) = ",
             nhst_smooth_pct, "% — matches strategy table]</span>")
    else
      paste0("❌ REJECT — lower CI (", round(ci_lower, 2),
             ") > 0; significant difference detected",
             " <span style='font-size:11px; color:#888;'>[smooth P(Approve) = ",
             nhst_smooth_pct, "% — matches strategy table]</span>")
    
    # Equivalence (TOST)
    equiv_smooth_pct <- round(plogis(clamp((ctx$d_R - ci_upper) / se, -10, 10)) * 100, 1)
    equiv_dec <- if (ci_upper < ctx$d_R)
      paste0("✅ APPROVE  — CI upper (", round(ci_upper, 2),
             ") < d_R (", ctx$d_R, "): difference within consumer tolerance",
             " <span style='font-size:11px; color:#888;'>[P(Approve) = ",
             equiv_smooth_pct, "%]</span>")
    else paste0("❌ REJECT  — CI upper (",
                round(ci_upper, 2), ") >= d_R (", ctx$d_R,
                "): cannot rule out consumer-relevant difference",
                " <span style='font-size:11px; color:#888;'>[P(Approve) = ",
                equiv_smooth_pct, "%]</span>")
    
    # Bayesian: three zones (Approve / Borderline / Reject)
    bayes_dec <- if (p_below > cutoff) {
      paste0(
        "✅ APPROVE — P(d' < d_R | data, flat prior) = ",
        round(p_below * 100, 1), "% (≥ ", round(cutoff * 100, 0), "% cutoff)."
      )
    } else if (p_below > 0.5) {
      paste0(
        "⚠️ BORDERLINE — P(d' < d_R | data, flat prior) = ",
        round(p_below * 100, 1), "% (< ", round(cutoff * 100, 0),
        "% cutoff). More data needed."
      )
    } else {
      paste0(
        "❌ REJECT — P(d' < d_R | data, flat prior) = ",
        round(p_below * 100, 1), "% (< 50%, effect likely ≥ d_R)."
      )
    }
    
    HTML(paste0(
      "<div style='font-size:13px; line-height:2.4;'>",
      "<b>NHST:</b> ", nhst_dec, "<br>",
      "<span style='font-size:11px; color:#888;'>Tests departure from zero only — d_R is irrelevant here. Approval = not significant.</span><br>",
      "<b>Equivalence (TOST):</b> ", equiv_dec, "<br>",
      "<span style='font-size:11px; color:#888;'>Approves only when the entire 95% CI lies below the consumer-relevant threshold d_R.</span><br>",
      "<b>Bayesian:</b> ", bayes_dec, "<br>",
      "<span style='font-size:11px; color:#888;'>Probability the true d' is smaller than d_R, given the data and a flat (uninformative) prior on d'.</span>",
      "</div>"
    ))
  })
  
  output$ds_strategy_table <- renderDT({
    df <- cur_strat(); if (is.null(df)) return(datatable(data.frame()))
    bs <- best_strategy_name(df)
    df$Rec <- ifelse(df$Strategy == bs, "★ Best", "")
    datatable(
      df, rownames = FALSE,
      options = list(dom = "t", pageLength = 5),
      colnames = c(
        "Strategy",
        "P(d'<d_R) [flat prior]",
        "P(Approve)",
        "P(App.&Diff)",
        "P(Rej.&Sim)",
        "Exp. Loss",
        ""
      )
    ) %>%
      formatStyle(
        "Expected Loss",
        background = styleColorBar(
          c(0, max(df$`Expected Loss`, 0.1)), "#fadbd8"
        )
      ) %>%
      formatStyle("Rec", color = "#1e8449", fontWeight = "bold") %>%
      formatStyle(
        "Strategy",
        fontWeight = styleEqual(bs, "bold"),
        backgroundColor = styleEqual(bs, "#d5f5e3")
      )
  })
  
  # expected loss vs N at assumed true d′
  output$ds_loss_curve <- renderPlotly({
    ctx    <- active_ctx()
    method <- input$global_method
    n_seq  <- seq(10, 250, 5)
    colors <- c("#e74c3c", "#3498db", "#2ecc71")
    
    pc <- TEST_DATA[[method]]$pc
    
    # Use slider value for the simulation, not necessarily d_R
    true_d <- input$ds_true_d
    if (is.null(true_d) || is.na(true_d)) true_d <- ctx$d_R
    
    # True pa at the assumed true d'
    pa_true <- pa_from_d(true_d, method, pc)
    
    p <- plot_ly()
    for (i in seq_along(STRAT_NAMES)) {
      s <- STRAT_NAMES[i]
      losses <- sapply(n_seq, function(n) {
        # Deterministic "typical" dataset at true_d: X = pa_true * N
        x_det <- pa_true * n
        cc2   <- calc_d_prime(n, x_det, TEST_DATA[[method]])
        if (is.na(cc2$d_prime)) return(NA)
        df2 <- calc_strategy_table(
          cc2$d_prime, cc2$se, ctx$d_R,   # still evaluate loss vs d_R
          ctx$alpha, input$ds_cost_miss, input$ds_cost_alarm
        )
        df2$`Expected Loss`[df2$Strategy == s]
      })
      p <- add_lines(
        p, x = n_seq, y = losses, name = s,
        line = list(color = colors[i], width = 2)
      )
    }
    
    p %>%
      layout(
        xaxis  = list(title = "N panelists"),
        yaxis  = list(title = "Expected Loss"),
        margin = list(t = 10)
      )
  })
  
  
  
  
  # ============================================================
  # TAB 4 — Scenario Projector
  # ============================================================
  
  portfolio <- reactiveVal(
    data.frame(
      Project = character(), Method = character(), Context_key = character(),
      Context_label = character(), N = integer(), X = integer(),
      d_R = numeric(), Alpha = numeric(), TargetPower = numeric(),
      CostMiss = numeric(), CostAlarm = numeric(),
      Importance = character(), Hours = numeric(),
      d_prime = numeric(), Power_pct = numeric(),
      P_below_dR = numeric(), Exp_Loss = numeric(),
      stringsAsFactors = FALSE
    )
  )
  
  observeEvent(input$sp_add, {
    m   <- input$sp_method
    n   <- input$sp_n
    x   <- input$sp_x
    ck  <- input$sp_context
    ctx <- CONTEXTS[[ck]]
    td  <- TEST_DATA[[m]]
    cc  <- calc_d_prime(n, x, td)
    pw  <- calc_power(n, ctx$d_R, m, td$pc, ctx$alpha)
    p_below <- if (!is.na(cc$d_prime)) pnorm(ctx$d_R, cc$d_prime, cc$se) else NA
    el <- if (!is.na(cc$d_prime)) {
      df_s <- calc_strategy_table(cc$d_prime, cc$se, ctx$d_R,
                                  ctx$alpha, ctx$cost_miss, ctx$cost_alarm)
      bs   <- best_strategy_name(df_s)
      df_s$`Expected Loss`[df_s$Strategy == bs]
    } else NA
    
    portfolio(rbind(portfolio(), data.frame(
      Project = input$sp_name, Method = m, Context_key = ck,
      Context_label = ctx$label, N = n, X = x,
      d_R = ctx$d_R, Alpha = ctx$alpha, TargetPower = ctx$target_power,
      CostMiss = ctx$cost_miss, CostAlarm = ctx$cost_alarm,
      Importance = input$sp_importance, Hours = input$sp_hours,
      d_prime = if (!is.na(cc$d_prime)) round(cc$d_prime, 3) else NA,
      Power_pct = round(pw * 100, 1),
      P_below_dR = if (!is.na(p_below)) round(p_below, 3) else NA,
      Exp_Loss   = if (!is.na(el))      round(el, 2)       else NA,
      stringsAsFactors = FALSE
    )))
  })
  
  observeEvent(input$sp_clear, portfolio(
    data.frame(
      Project = character(), Method = character(), Context_key = character(),
      Context_label = character(), N = integer(), X = integer(),
      d_R = numeric(), Alpha = numeric(), TargetPower = numeric(),
      CostMiss = numeric(), CostAlarm = numeric(),
      Importance = character(), Hours = numeric(),
      d_prime = numeric(), Power_pct = numeric(),
      P_below_dR = numeric(), Exp_Loss = numeric(),
      stringsAsFactors = FALSE
    )
  ))
  
  adj_portfolio <- reactive({
    df <- portfolio(); if (nrow(df) == 0) return(df)
    df$N_adj <- ceiling(df$N * (1 + input$sp_n_boost / 100))
    for (i in seq_len(nrow(df))) {
      m   <- df$Method[i]; td <- TEST_DATA[[m]]
      n2  <- df$N_adj[i];  a2 <- input$sp_alpha_tight
      d_r <- df$d_R[i]
      # H3 fix: N-boost is a prospective power question.
      # We ask: "if we ran n2 panelists, what power would we have at d_R?"
      # d' and P_below_dR are properties of the OBSERVED data (original N, X)
      # and do not change when we hypothetically increase N.
      # Only Power_pct is recomputed with the boosted N.
      df$Power_pct[i] <- round(calc_power(n2, d_r, m, td$pc, a2) * 100, 1)
      # d_prime and P_below_dR remain as stored from sp_add (original N and X)
      # Exp_Loss also stays fixed — it reflects the current data's uncertainty
    }
    # Status: Green = prospective power >= target AND observed P(d'<d_R) >= 0.80
    #         Amber = power OK but P(d'<d_R) between 0.60–0.80
    #         Red   = underpowered OR P(d'<d_R) < 0.60
    df$Status <- mapply(function(pw, pb, tp) {
      if (is.na(pw) || is.na(pb)) return("\U0001F534 No data")
      if (pw >= tp * 100 && pb >= 0.80) "\u2705 Low risk"
      else if (pw >= tp * 100 && pb >= 0.60) "\u26A0\uFE0F Moderate risk"
      else "\U0001F534 High risk"
    }, df$Power_pct, df$P_below_dR, df$TargetPower)
    df
  })
  
  output$sp_portfolio_table <- renderDT({
    df <- adj_portfolio()
    if (nrow(df) == 0) return(datatable(data.frame(Note = "No projects added yet.")))
    display <- df[, c("Project","Method","Context_label","N_adj","d_R",
                      "d_prime","Power_pct","P_below_dR","Exp_Loss",
                      "Importance","Hours","Status")]
    names(display) <- c(
      "Project", "Method", "Decision Context",
      "N (adjusted)", "Consumer-relevant diff. (d_R)",
      "Observed d'", "Power at d_R (%)", "Brand safety score",
      "Brand risk (exp. loss)", "Strategic importance",
      "Panel hours", "Risk status"
    )
    datatable(display, rownames = FALSE,
              options = list(pageLength = 10, scrollX = TRUE, dom = "tp")) %>%
      formatStyle("Risk status",
                  backgroundColor = styleEqual(
                    c("\u2705 Low risk","\u26A0\uFE0F Moderate risk",
                      "\U0001F534 High risk","\U0001F534 No data"),
                    c("#dff0d8","#fcf8e3","#f2dede","#f5f5f5"))) %>%
      formatStyle("Power at d_R (%)",
                  color = styleInterval(c(60, 80), c("#cc0000","#cc6600","#2e7d32")),
                  fontWeight = "bold") %>%
      formatStyle("Brand safety score",
                  color = styleInterval(c(0.60, 0.80), c("#cc0000","#cc6600","#2e7d32")))
  })
  
  output$sp_total_hours <- renderText({
    df <- adj_portfolio()
    if (nrow(df) == 0) return("0 hrs")
    paste0(sum(df$Hours, na.rm = TRUE), " hrs")
  })
  
  output$sp_underpowered <- renderText({
    df <- adj_portfolio(); if (nrow(df) == 0) return("0")
    as.character(sum(df$Power_pct < df$TargetPower * 100, na.rm = TRUE))
  })
  
  output$sp_brand_risk <- renderText({
    df <- adj_portfolio(); if (nrow(df) == 0) return("—")
    hi <- df[df$Importance == "High", ]
    if (nrow(hi) == 0) return("0")
    as.character(round(sum(hi$Exp_Loss, na.rm = TRUE), 1))
  })
}

shinyApp(ui = ui, server = server)
