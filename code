# SECTION 2 — STATISTICAL ENGINE
# ============================================================

calc_se <- function(n, pa, pc, test_name) {
  pa     <- max(pc + 1e-6, min(0.9999, pa))
  phi_pa <- dnorm(qnorm(pa))
  if (test_name %in% c("Triangle", "Duo-Trio")) {
    phi_pc <- dnorm(qnorm(pc))
    sqrt((phi_pa^2 * pa * (1 - pa)) / (n * (phi_pa^2 + phi_pc^2)))
  } else {
    sqrt((pa * (1 - pa)) / (n * phi_pa^2))
  }
}

calc_d_prime <- function(n, x, test_data) {
  if (n <= 0 || x < 0 || x > n) return(list(d_prime = NA, se = NA, pa = NA))
  pa   <- x / n
  pc   <- test_data$pc
  name <- test_data$test_name
  if (pa <= pc) pa <- pc + 0.001
  if (pa >= 1)  pa <- 0.999
  d <- switch(name,
              # A-not-A: yes/no task against internalised criterion.
              # SDT formula: d' = z(pa) — NO sqrt(2) factor.
              # sqrt(2) belongs to 2AFC (decision variable = difference of two N(0,1)).
              "A-not-A" = qnorm(pa),
              # 2AFC: d' = sqrt(2) * z(pa)  — standard Thurstonian 2AFC result
              "2AFC"    = qnorm(pa) * sqrt(2),
              # 3AFC: 1.128 is the Ashby & Townsend (1986) approximation valid near pc.
              # Exact relationship requires numerical integration (cf. sensR::pc2dp).
              "3AFC"    = qnorm(pa) * sqrt(2) * 1.128,
              # Triangle: non-directional; d' = z(pa) - z(pc) (Thurstonian / Stanislaw & Todorov)
              "Triangle"= qnorm(pa) - qnorm(pc),
              # Tetrad: 1.414 approximation (Ennis 2012). Exact via numerical integration.
              "Tetrad"  = qnorm(pa) * sqrt(2) * 1.414,
              # Duo-Trio (constant-reference): same decision structure as 2AFC; d' = z(pa) - z(pc)
              "Duo-Trio"= qnorm(pa) - qnorm(pc)
  )
  # SE formulas:
  # A-not-A (SDT yes/no): SE = 1 / (sqrt(n) * phi(z_pa))
  # This follows from the MLE delta method for a single-sample SDT task.
  # It differs from the 2AFC SE because A-not-A has only one observation per trial,
  # not a difference of two.
  se <- if (name == "A-not-A")
    1 / (sqrt(n) * dnorm(qnorm(pa)))
  else
    calc_se(n, pa, pc, name)
  list(d_prime = d, se = se, pa = pa)
}

pa_from_d <- function(d, test_name, pc) {
  switch(test_name,
         # A-not-A: d' = qnorm(pa)  →  pa = pnorm(d)   [no sqrt(2)]
         "A-not-A" = pnorm(d),
         # 2AFC:    d' = sqrt(2)*qnorm(pa)  →  pa = pnorm(d/sqrt(2))
         "2AFC"    = pnorm(d / sqrt(2)),
         "3AFC"    = pnorm(d / (sqrt(2) * 1.128)),
         "Triangle"= pnorm(qnorm(pc) + d),
         "Tetrad"  = pnorm(d / (sqrt(2) * 1.414)),
         "Duo-Trio"= pnorm(qnorm(pc) + d)
  )
}

# Exact binomial power
calc_power <- function(n, d, test_name, pc, alpha = 0.05) {
  if (n < 1 || d <= 0) return(0)
  pa_true <- pa_from_d(d, test_name, pc)
  x_crit  <- qbinom(1 - alpha, n, pc) + 1
  1 - pbinom(x_crit - 1, n, pa_true)
}

calc_min_n <- function(d, test_name, pc, alpha = 0.05, power_target = 0.80) {
  for (n in 5:500) if (calc_power(n, d, test_name, pc, alpha) >= power_target) return(n)
  return(NA)
}

calc_ci <- function(d_prime, se, pa, n, pc) {
  z     <- qnorm(0.975)
  se_pa <- sqrt(pa * (1 - pa) / n)
  list(
    d_ci  = c(d_prime - z * se, d_prime + z * se),
    pa_ci = c(max(0, pa - z * se_pa), min(1, pa + z * se_pa)),
    pd    = pa - pc,
    pd_ci = c(max(0, pa - z * se_pa - pc), min(1 - pc, pa + z * se_pa - pc))
  )
}

# ------------------------------------------------------------------
# PRINCIPLED decision-strategy layer
#
# NHST    : approves when no significant difference from zero
#           (pure significance logic — d_R is irrelevant here)
# Equiv.  : approves when CI upper < d_R (TOST-style)
# Bayesian: P(d' < d_R | data) — flat prior, posterior ~ N(d', SE^2)
#
# All approval probs use a smooth logistic mapping so that
# expected-loss curves are continuous near boundaries.
#
# p_sim  = P(d' < d_R | data)   [likelihood-based posterior, flat prior]
# p_diff = 1 - p_sim
# Expected loss = cost_miss * p_diff * p_approve
#               + cost_alarm * p_sim  * (1 - p_approve)
# ------------------------------------------------------------------
calc_strategy_table <- function(d_prime, se, d_R, alpha, cost_miss, cost_alarm) {
  
  # z levels:
  #   z_nhst  — one-tailed critical value used for NHST significance test (H0: d'=0, HA: d'>0)
  #   z_ci    — two-tailed 95% CI multiplier (alpha=0.05 regardless of context alpha,
  #             because CIs are always reported at 95% for interpretability)
  z_nhst   <- qnorm(1 - alpha)        # one-tailed: depends on context alpha
  z_ci     <- qnorm(0.975)            # two-tailed: always 95% CI
  
  ci_upper <- d_prime + z_ci * se
  ci_lower <- d_prime - z_ci * se
  
  # Posterior probability under flat prior: P(d' < d_R | data) ~ N(d_prime, se^2)
  p_sim  <- pnorm(d_R, mean = d_prime, sd = se)
  p_diff <- 1 - p_sim
  
  # ---------------------------------------------------------------------------
  # Smooth logistic approval probabilities.
  # Margins are clamped to [-10, 10] before plogis to avoid Inf/-Inf overflow
  # when SE is very small (e.g. large N) or d_prime is far from boundary.
  # plogis(margin) → 1 when margin >> 0 (strong approval),
  #                  0 when margin << 0 (strong rejection),
  #                  0.5 when exactly on the boundary.
  # ---------------------------------------------------------------------------
  
  # NHST: approve when the test fails to reject H0 (d' not significantly > 0).
  # Margin = how far the lower 95% CI bound lies above zero.
  # Positive margin → lower CI > 0 → significant (lean reject).
  # We want P(Approve) high when NOT significant, so we negate:
  # nhst_margin > 0 means "lower CI above 0" i.e. sig diff → reject.
  # Therefore: nhst_approve = plogis(-nhst_margin).
  # Equivalently: nhst_approve = plogis((0 - ci_lower) / se).
  # Note: NHST deliberately ignores d_R. Equivalence carries the d_R logic.
  nhst_margin  <- clamp((ci_lower - 0) / se, -10, 10)   # positive = sig diff
  nhst_approve <- plogis(-nhst_margin)                   # negate: high when not sig
  
  # Equivalence (TOST-style): approve when the 95% CI lies entirely below d_R.
  # Rule: ci_upper < d_R  ↔  d_R - ci_upper > 0.
  # Margin = (d_R - ci_upper) / se: positive when CI upper is safely below d_R.
  equiv_margin  <- clamp((d_R - ci_upper) / se, -10, 10)
  equiv_approve <- plogis(equiv_margin)
  
  # Bayesian (flat prior): P(d' < d_R | data) is directly the approval weight.
  # No logistic needed — the probability is already continuous and bounded [0,1].
  bayes_approve <- p_sim
  
  strats    <- STRAT_NAMES   # single source of truth — also used in ds_loss_curve
  p_app_vec <- c(nhst_approve, equiv_approve, bayes_approve)
  
  rows <- lapply(seq_along(strats), function(i) {
    pa   <- p_app_vec[i]
    pr   <- 1 - pa
    loss <- cost_miss * p_diff * pa + cost_alarm * p_sim * pr
    data.frame(
      Strategy              = strats[i],
      "P(d' < d_R)"         = round(p_sim,       3),
      "P(Approve)"          = round(pa,          3),
      "P(App. & Diff.)"     = round(p_diff * pa, 3),
      "P(Rej. & Similar)"   = round(p_sim  * pr, 3),
      "Expected Loss"       = round(loss,        2),
      check.names = FALSE, stringsAsFactors = FALSE
    )
  })
  do.call(rbind, rows)
}

# Helper: clamp x to [lo, hi]
clamp <- function(x, lo, hi) pmax(lo, pmin(hi, x))

best_strategy_name <- function(df) df$Strategy[which.min(df$`Expected Loss`)]

# Consumer-relevant verdict (CI vs d_R)
verdict_text <- function(d_prime, se, d_R) {
  if (is.na(d_prime)) return(list(text = "No data", color = "gray", detail = "Enter N and X.", p_below = NA))
  ci_lo   <- d_prime - qnorm(0.975) * se
  ci_hi   <- d_prime + qnorm(0.975) * se
  p_below <- pnorm(d_R, d_prime, se)   # flat-prior posterior
  if (ci_hi < d_R)
    list(text    = "Within consumer tolerance",
         color   = "green",
         p_below = p_below,
         detail  = paste0(
           "95% CI [", round(ci_lo, 2), ", ", round(ci_hi, 2), "] lies entirely below ",
           "the consumer-relevant difference d_R = ", d_R, ". ",
           "The observed sensory difference is unlikely to be noticeable to consumers."))
  else if (ci_lo > d_R)
    list(text    = "Exceeds consumer tolerance",
         color   = "red",
         p_below = p_below,
         detail  = paste0(
           "95% CI [", round(ci_lo, 2), ", ", round(ci_hi, 2), "] lies entirely above ",
           "d_R = ", d_R, ". ",
           "The observed difference is likely noticeable to consumers."))
  else
    list(text    = "Inconclusive around d_R",
         color   = "orange",
         p_below = p_below,
         detail  = paste0(
           "95% CI [", round(ci_lo, 2), ", ", round(ci_hi, 2), "] straddles ",
           "d_R = ", d_R, ". ",
           "More panelists are needed to resolve whether the difference is consumer-relevant."))
}

# Power-at-d_R sentence
power_sentence <- function(methods, n, d_R, alpha) {
  parts <- sapply(methods, function(m) {
    pc <- TEST_DATA[[m]]$pc
    pw <- calc_power(n, d_R, m, pc, alpha)
    paste0(m, ": ", round(pw * 100, 1), "%")
  })
  paste0("At d_R = ", d_R, " and N = ", n, "  |  ", paste(parts, collapse = "  |  "))
}

